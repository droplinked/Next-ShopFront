    "preinstall": "node ./scripts/preinstall-supply-chain-guard.js",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "prod": "next start -p 80",
    "lint": "next lint",
    "test": "node --test 'src/__smoke__/*.test.mjs'",
